package com.salonai.ai.controller;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.salonai.ai.dto.AiBookingRequest;
import com.salonai.ai.service.ConversationMemoryService;
import com.salonai.service.entity.SalonService;
import com.salonai.service.service.BusinessService;
import org.springframework.ai.chat.client.ChatClient;
import org.springframework.web.bind.annotation.*;

import java.time.DayOfWeek;
import java.time.LocalDate;
import java.time.temporal.TemporalAdjusters;
import java.util.List;
import java.util.stream.Collectors;

@RestController
@RequestMapping("/api/ai")
public class AiController {

    private final ChatClient chatClient;

    private final BusinessService businessService;

    private final ObjectMapper objectMapper;

    private final ConversationMemoryService memoryService;

    public AiController(
            ChatClient.Builder builder,
            BusinessService businessService,
            ObjectMapper objectMapper,
            ConversationMemoryService memoryService
    ) {

        this.chatClient = builder.build();

        this.businessService = businessService;

        this.objectMapper = objectMapper;

        this.memoryService = memoryService;
    }

    @PostMapping("/chat")
    public Object chat(
            @RequestBody java.util.Map<String, String> request
    ) {

        try {

            String sessionId =
                    request.get("sessionId");

            String message =
                    request.get("message");

            List<SalonService> services =
                    businessService.getAllServices();

            String serviceData =
                    services.stream()
                            .map(SalonService::getName)
                            .collect(Collectors.joining(", "));

            String prompt = """
                    You are a salon booking extraction engine.

                    AVAILABLE SERVICES:
                    %s

                    RULES:
                    - Return ONLY valid JSON
                    - No markdown
                    - No explanations
                    - No comments
                    - No extra text
                    - Never invent services
                    - If service not provided return UNKNOWN
                    - Time format HH:mm
                    - Return relative dates exactly as user said

                    Examples:
                    today
                    tomorrow
                    sunday
                    monday
                    next friday
                    morning
                    evening

                    VALID RESPONSE FORMAT:

                    {
                      "intent": "",
                      "service": "",
                      "date": "",
                      "time": ""
                    }

                    VALID INTENTS:
                    BOOK
                    RECOMMEND
                    UNKNOWN
                    """.formatted(serviceData);

            String response =
                    chatClient.prompt()
                            .system(prompt)
                            .user(message)
                            .call()
                            .content()
                            .trim();

            response = cleanJson(response);

            AiBookingRequest aiRequest =
                    objectMapper.readValue(
                            response,
                            AiBookingRequest.class
                    );

            // NORMALIZE DATE
            aiRequest.setDate(
                    normalizeDate(
                            aiRequest.getDate()
                    )
            );

            // NORMALIZE TIME
            aiRequest.setTime(
                    normalizeTime(
                            aiRequest.getTime()
                    )
            );

            // FUZZY SERVICE MATCHING
            String matchedService = services.stream()
                    .map(SalonService::getName)
                    .filter(serviceName ->
                            aiRequest.getService() != null
                                    &&
                                    (
                                            serviceName.toLowerCase()
                                                    .contains(
                                                            aiRequest.getService()
                                                                    .toLowerCase()
                                                    )
                                                    ||
                                                    aiRequest.getService()
                                                            .toLowerCase()
                                                            .contains(
                                                                    serviceName.toLowerCase()
                                                            )
                                    )
                    )
                    .findFirst()
                    .orElse("UNKNOWN");

            aiRequest.setService(matchedService);

            // SAVE MEMORY
            memoryService.saveField(
                    sessionId,
                    "service",
                    aiRequest.getService()
            );

            memoryService.saveField(
                    sessionId,
                    "date",
                    aiRequest.getDate()
            );

            memoryService.saveField(
                    sessionId,
                    "time",
                    aiRequest.getTime()
            );

            // MERGE MEMORY
            if (aiRequest.getService() == null
                    || aiRequest.getService().isBlank()
                    || aiRequest.getService().equals("UNKNOWN")) {

                aiRequest.setService(
                        memoryService.getField(
                                sessionId,
                                "service"
                        )
                );
            }

            if (aiRequest.getDate() == null
                    || aiRequest.getDate().isBlank()) {

                aiRequest.setDate(
                        memoryService.getField(
                                sessionId,
                                "date"
                        )
                );
            }

            if (aiRequest.getTime() == null
                    || aiRequest.getTime().isBlank()) {

                aiRequest.setTime(
                        memoryService.getField(
                                sessionId,
                                "time"
                        )
                );
            }

            // CHECK MISSING SERVICE
            if (aiRequest.getService() == null
                    || aiRequest.getService().isBlank()
                    || aiRequest.getService().equals("UNKNOWN")) {

                aiRequest.setMissingField("service");

                aiRequest.setUserMessage(
                        "Which service would you like to book?"
                );

                return aiRequest;
            }

            // CHECK MISSING DATE
            if (aiRequest.getDate() == null
                    || aiRequest.getDate().isBlank()) {

                aiRequest.setMissingField("date");

                aiRequest.setUserMessage(
                        "Please provide preferred booking date."
                );

                return aiRequest;
            }

            // CHECK MISSING TIME
            if (aiRequest.getTime() == null
                    || aiRequest.getTime().isBlank()) {

                aiRequest.setMissingField("time");

                aiRequest.setUserMessage(
                        "Please provide preferred booking time."
                );

                return aiRequest;
            }

            // FINAL USER MESSAGE
            aiRequest.setUserMessage(
                    "Your "
                            + aiRequest.getService()
                            + " appointment request is prepared for "
                            + aiRequest.getDate()
                            + " at "
                            + aiRequest.getTime()
            );

            return aiRequest;

        } catch (Exception e) {

            return java.util.Map.of(
                    "error",
                    "AI parsing failed",

                    "details",
                    e.getMessage()
            );
        }
    }

    private String cleanJson(
            String response
    ) {

        int start =
                response.indexOf("{");

        int end =
                response.lastIndexOf("}");

        if (start >= 0 && end >= 0) {

            response =
                    response.substring(
                            start,
                            end + 1
                    );
        }

        response = response.replace("```json", "");

        response = response.replace("```", "");

        return response.trim();
    }

    private String normalizeDate(
            String input
    ) {

        if (input == null
                || input.isBlank()) {

            return "";
        }

        input =
                input.toLowerCase().trim();

        LocalDate today =
                LocalDate.now();

        switch (input) {

            case "today":
                return today.toString();

            case "tomorrow":
                return today.plusDays(1).toString();

            case "sunday":
                return today.with(
                        TemporalAdjusters.next(
                                DayOfWeek.SUNDAY
                        )
                ).toString();

            case "monday":
                return today.with(
                        TemporalAdjusters.next(
                                DayOfWeek.MONDAY
                        )
                ).toString();

            default:
                return input;
        }
    }

    private String normalizeTime(
            String input
    ) {

        if (input == null
                || input.isBlank()) {

            return "";
        }

        input =
                input.toLowerCase().trim();

        switch (input) {

            case "morning":
                return "10:00";

            case "afternoon":
                return "14:00";

            case "evening":
                return "18:00";

            case "night":
                return "20:00";

            default:
                return input;
        }
    }
}